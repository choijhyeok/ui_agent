# Shared
PROJECT_NAME=local-figma
POSTGRES_DB=local_figma
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=55432

# Service ports
WEB_HOST_PORT=3000
AGENT_HOST_PORT=8123
RUNTIME_HOST_PORT=3001

# Agent provider selection
# Supported values: openai | azure-openai
# Compatibility alias accepted by bootstrap: azure -> azure-openai
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Persistence
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/local_figma
